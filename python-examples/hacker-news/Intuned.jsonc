// For more information, see our Intuned settings reference
// https://intunedhq.com/docs/main/05-references/intuned-json
{
  "apiAccess": {
    "enabled": false
  },
  "authSessions": {
    "enabled": false
  },
  "replication": {
    "maxConcurrentRequests": 1,
    "size": "standard"
  },
  "metadata": {
    "template": {
      "name": "hacker-news",
      "description": "Daily Hacker News digest: scrape the front page, translate/classify/summarize with an LLM in Chinese, and push to Telegram",
      "tags": [
        "scraping",
        "crawling",
        "browser-sdk"
      ]
    },
    "defaultRunPlaygroundInput": {
      "apiName": "daily-digest",
      "parameters": {
        "pages": 1,
        "limit": 10,
        "send": false
      }
    }
  }
}
