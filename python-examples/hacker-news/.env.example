# Copy to .env and fill in your own values. .env is gitignored — never commit secrets.

# --- OpenAI / LLM (Chinese translation, classification, summary) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat to push the digest to (user, group, or channel id)
TELEGRAM_APPROVAL_CHAT_ID=your_chat_id_here
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Optional: only needed if you build a Telegram webhook/approval flow on top of this
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# --- Intuned ---
INTUNED_API_KEY=your_api_key_here
