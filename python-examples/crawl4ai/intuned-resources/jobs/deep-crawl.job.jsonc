{
  "configuration": {
    "maxConcurrentRequests": 2,
    "retry": {
      "maximumAttempts": 3
    }
  },
  "payload": [
    {
      "apiName": "deep-crawl",
      "parameters": {
        "url": "https://playwright.dev/docs/intro",
        "strategy": "bfs",
        "max_depth": 3,
        "max_pages": 20,
        "url_patterns": [
          "*docs*"
        ],
        "stream": true
      }
    }
  ]
}
